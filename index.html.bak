// STEP 1.5: Also set Module.wasmBinary early so STEP 2's inline code can use it
// This runs synchronously after the IIFE above
Module.wasmBinary = window.__lo3_wasm_bytes;

// Deferred callback for when WASM is ready (set by STEP 2's run() call)
window.__wasmbinaryReadyCallbacks = window.__wasmbinaryReadyCallbacks || [];
// Check if STEP 2 already tried to instantiate — if so, trigger its callbacks
if (Module.wasmBinary && typeof WebAssembly !== "undefined") {
  window.__wasmbinaryReadyCallbacks.forEach(function(cb) { cb(); });
  window.__wasmbinaryReadyCallbacks = [];
}

var Module = {
  locateFile: locateFile,
  wasmBinaryFile: "lo3.wasm",
  print:    function(t) { _outAccum += t + '\n'; },
  printErr: function(t) { _errAccum += t + '\n'; },
  noInitialRun: true,
  onRuntimeInitialized: function() {
    window._lo3Ready = true;
    window._lo3Run = Module.cwrap('lo3_run', 'number', ['string']);
    window._lo3Ver = Module.UTF8ToString(Module._lo3_version());
    // Signal UI
    if (window._onWasmReady) window._onWasmReady();
  }
};

// Restore wasmBinary that was set in STEP 1
Module.wasmBinary = window.__lo3_wasm_bytes;
</script>

